{
  "name": "luacretro",
  "version": "0.1.0",
  "description": "The shared Lua compiler front-end for the gtlua / gbalua / mdlua / neslua / c64lua console SDKs: a PICO-8-flavored Lua subset compiled to C for GameTank (6502), Game Boy Advance (ARM), Sega Genesis (68000), NES (6502), and Commodore 64 (6510).",
  "type": "module",
  "license": "MIT",
  "author": "Luis Montes",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": "./compiler/index.js",
    "./lexer": "./compiler/lexer.js",
    "./parser": "./compiler/parser.js",
    "./check": "./compiler/check.js",
    "./emit": "./compiler/emit.js",
    "./peephole": "./compiler/peephole.js",
    "./core-builtins": "./compiler/core-builtins.js",
    "./package.json": "./package.json"
  },
  "files": [
    "compiler",
    "README.md",
    "LICENSE",
    "SPEC.md"
  ],
  "scripts": {
    "test": "node --test 'test/**/*.test.js'"
  },
  "keywords": [
    "lua",
    "pico-8",
    "pico8",
    "gamedev",
    "game-development",
    "retro",
    "retrogaming",
    "homebrew",
    "rom",
    "wasm",
    "webassembly",
    "ahead-of-time",
    "aot",
    "compiler",
    "lua-to-c",
    "transpiler",
    "console",
    "sdk",
    "6502",
    "68000",
    "arm",
    "cc65",
    "gametank",
    "gba",
    "game-boy-advance",
    "genesis",
    "nes",
    "c64",
    "commodore-64"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monteslu/luacretro.git"
  },
  "homepage": "https://github.com/monteslu/luacretro#readme",
  "bugs": {
    "url": "https://github.com/monteslu/luacretro/issues"
  }
}
